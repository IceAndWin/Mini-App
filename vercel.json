{
  "buildCommand": "npm run build && cd admin && npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install && cd admin && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "crons": [
    { "path": "/api/cron/check-reminders", "schedule": "0 8 * * *" }
  ]
}
